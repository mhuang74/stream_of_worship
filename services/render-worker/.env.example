# Database connection — Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Cloudflare R2 (S3-compatible) storage configuration
R2_BUCKET=your-r2-bucket-name
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# AWS region for SQS and Lambda
AWS_REGION=us-east-1

# SQS queue URL for render job messages
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/sow-render-jobs
