# Stream of Worship - Analysis Service - Environment Configuration
# Copy this file to .env and configure for your environment

# ========================================
# R2 Storage Configuration (Required)
# ========================================

SOW_R2_ACCESS_KEY_ID="your-r2-access-key-id"
# Cloudflare R2 access key ID
# Get from Cloudflare R2 dashboard: Manage R2 API Tokens

SOW_R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
# Cloudflare R2 secret access key
# Get from Cloudflare R2 dashboard: Manage R2 API Tokens

SOW_R2_ENDPOINT_URL="https://<account-id>.r2.cloudflarestorage.com"
# R2 API endpoint URL
# Replace <account-id> with your Cloudflare account ID
# Example: https://6c80769fe5aa4be53908b83c3d0454cd.r2.cloudflarestorage.com

SOW_R2_BUCKET="your-bucket-name"
# Cloudflare R2 bucket name for audio storage
# Example: stream-of-worship

# ========================================
# API Security (Required)
# ========================================

SOW_ADMIN_API_KEY="your-secure-admin-key"
# API key for admin-only operations (job cancellation, clear queue)
# If not set, admin endpoints return 503 Service Unavailable
# Generate a secure random string, e.g.:
#   openssl rand -base64 32
# Note: Must be different from SOW_ANALYSIS_API_KEY

# ========================================

SOW_ANALYSIS_API_KEY="your-secure-random-key"
# API key for authentication (shared with Admin CLI)
# Generate a secure random string, e.g.:
#   openssl rand -base64 32

# ========================================
# LLM Configuration (Required for LRC generation)
# ========================================

SOW_LLM_API_KEY="sk-or-v1-..."
# OpenAI-compatible API key for LRC generation
# Supports: OpenRouter, OpenAI, NeuralWatt, etc.
# Example (OpenRouter): sk-or-v1-1234567890abcdef...

SOW_LLM_BASE_URL="https://openrouter.ai/api/v1"
# LLM API base URL
# Examples:
#   - OpenRouter: https://openrouter.ai/api/v1
#   - OpenAI: https://api.openai.com/v1
#   - NeuralWatt: https://api.neuralwatt.com/v1/chat/completions

SOW_LLM_MODEL="openai/gpt-4o-mini"
# LLM model identifier
# Examples:
#   - OpenRouter: openai/gpt-4o-mini, google/gemini-flash-1.5
#   - OpenAI: gpt-4o-mini, gpt-4o
#   - NeuralWatt: Qwen/Qwen3.6-35B-A3B

# ========================================
# HuggingFace Qwen3 Model Configuration (Required for LRC refinement)
# ========================================

# HuggingFace caches models with symlinks (snapshots/ -> blobs/).
# To preserve symlinks in Docker, mount the PARENT directory.

SOW_QWEN3_MODEL_ROOT="/home/user/.cache/huggingface/hub/models--Qwen--Qwen3-ForcedAligner-0.6B"
# Parent HuggingFace cache directory (contains blobs/ and snapshots/)
# Find this path after downloading the model:
#   ls ~/.cache/huggingface/hub/ | grep Qwen
# To download: huggingface-cli download Qwen/Qwen3-ForcedAligner-0.6B

SOW_QWEN3_MODEL_SNAPSHOT="c7cbfc2048c462b0d63a45797104fc9db3ad62b7"
# Snapshot hash from HuggingFace cache
# Find this by listing the snapshots directory:
#   ls ~/.cache/huggingface/hub/models--Qwen--Qwen3-ForcedAligner-0.6B/snapshots/

# ========================================
# Audio-Separator Model Configuration (Required for stem separation)
# ========================================

SOW_AUDIO_SEPARATOR_MODEL_ROOT="/home/user/.cache/audio-separator"
# Host path to pre-downloaded audio-separator models
# Models are downloaded once and bind-mounted into the container
#
# To download models, run this Python script on your host:
#
#   from audio_separator.separator import Separator
#   import os
#
#   model_dir = "/home/user/.cache/audio-separator"
#   os.makedirs(model_dir, exist_ok=True)
#
#   print("Downloading BS-Roformer model...")
#   sep1 = Separator(output_dir=model_dir, output_format="FLAC")
#   sep1.load_model(model_filename="model_bs_roformer_ep_317_sdr_12.9755.ckpt")
#
#   print("Downloading UVR-De-Echo model...")
#   sep2 = Separator(output_dir=model_dir, output_format="FLAC")
#   sep2.load_model(model_filename="UVR-De-Echo-Normal.pth")
#
#   print(f"Models downloaded to: {model_dir}")

# ========================================
# Processing Configuration (Optional)
# ========================================

SOW_MAX_CONCURRENT_ANALYSIS_JOBS=1
# Maximum concurrent analysis jobs (default: 1)
# Analysis uses allin1 which is memory/CPU intensive, so serialized by default

SOW_MAX_CONCURRENT_LRC_JOBS=2
# Maximum concurrent LRC jobs (default: 2)
# faster-whisper is more efficient, allows limited concurrency

SOW_MAX_CONCURRENT_STEM_SEPARATION_JOBS=1
# Maximum concurrent stem separation jobs (default: 1)
# BS-Roformer is memory/CPU intensive, so serialized by default

SOW_DEMUCS_DEVICE=cpu
# Device for Demucs stem separation (default: cpu)
# Options: cpu, cuda
# Note: Requires GPU setup if using cuda (see GPU Support section in README)

SOW_WHISPER_DEVICE=cpu
# Device for Whisper transcription (default: cpu)
# Options: cpu, cuda
# Note: Requires GPU setup if using cuda (see GPU Support section in README)

# ========================================
# Stem Separation Model Selection (Optional)
# ========================================

SOW_BS_ROFORMER_MODEL="model_bs_roformer_ep_317_sdr_12.9755.ckpt"
# BS-Roformer model filename for vocal separation (Stage 1)
# Default: model_bs_roformer_ep_317_sdr_12.9755.ckpt

SOW_DEREVERB_MODEL="UVR-De-Echo-Normal.pth"
# UVR-De-Echo model filename for reverb removal (Stage 2)
# Options:
#   - UVR-De-Echo-Normal.pth (default, balanced)
#   - UVR-De-Echo-Aggressive.pth (stronger echo removal)
#   - UVR-DeEcho-DeReverb.pth (combined de-echo and de-reverb)

# ========================================
# Docker Build Configuration (Optional)
# ========================================

TARGETPLATFORM=linux/amd64
# Target platform for Docker build
# Options: linux/amd64, linux/arm64
# Docker Compose only: used in build args for multi-platform support
# For Apple Silicon Macs: linux/arm64
