{
  "framework": "nextjs",
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --frozen-lockfile",
  "functions": {
    "src/app/api/render-jobs/route.ts": {
      "maxDuration": 800,
      "fluid": true
    },
    "src/app/api/render-jobs/[id]/route.ts": {
      "maxDuration": 800,
      "fluid": true
    },
    "src/app/api/render-jobs/[id]/events/route.ts": {
      "maxDuration": 800,
      "fluid": true
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true,
      "*": true
    }
  },
  "headers": [
    {
      "source": "/songsets/:id/play/projection",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    },
    {
      "source": "/share/:token/play/projection",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache" }
      ]
    },
    {
      "source": "/_next/static/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "regions": ["iad1"]
}
