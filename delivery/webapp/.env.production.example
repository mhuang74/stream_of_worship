# =============================================================================
# Stream of Worship Web App — Production Environment Variables
# =============================================================================
# Copy this file to .env.production.local and fill in real values.
# NEVER commit .env.production.local to version control.
# In Vercel: add these via Project Settings → Environment Variables.
#
# Variables prefixed NEXT_PUBLIC_ are embedded in the client bundle.
# All others are server-only secrets.

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
# Connection string for the Neon serverless PostgreSQL database.
# Format: postgresql://user:password@host/dbname?sslmode=require
SOW_DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-1.aws.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Cloudflare R2 Object Storage
# -----------------------------------------------------------------------------
# R2 credentials for storing rendered audio (MP3) and video (MP4) files.
# Create an API token in the Cloudflare dashboard with R2 object read/write.
SOW_R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
SOW_R2_ACCESS_KEY_ID=your-r2-access-key-id
SOW_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
SOW_R2_BUCKET=stream-of-worship-prod

# Public domain for R2 bucket (set up a custom domain in Cloudflare R2 settings,
# or use the generated r2.dev public URL if bucket public access is enabled).
# Used to generate direct download/stream URLs for rendered files.
NEXT_PUBLIC_R2_PUBLIC_DOMAIN=https://assets.your-domain.com

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# Random 32+ character secret for signing session tokens.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters

# Base URL of the deployed app (no trailing slash).
BETTER_AUTH_URL=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# Google Cast SDK — Receiver App ID (Default Media Receiver is the v3 default)
# -----------------------------------------------------------------------------
# Cast receiver application ID from the Google Cast SDK Developer Console.
# https://cast.google.com/publish
#
# v3 default: leave this BLANK to use Google's built-in Default Media Receiver
# constant (`chrome.cast.media.DEFAULT_MEDIA_RECEIVER_APP_ID`). The Default
# Media Receiver is the only supported v3 mode — the lyrics are baked into the
# rendered MP4, so no custom on-receiver UI is required. The TV receiver streams
# the MP4 directly from R2 and never authenticates against the webapp; the
# logged-in phone (or public share-token route) mints the presigned R2 URL
# with a 4-hour expiry (`/api/signed-url?cast=true` or `/api/share/[token]`)
# and hands it to the TV.
#
# REQUIRED for dev/staging: register your Cast test devices by serial number
# under "Device registration" in the Cast SDK Developer Console. Only
# whitelisted devices can cast during dev/staging.
#
# Production launch gate: before public launch, submit the receiver for Cast
# review via the Cast SDK Developer Console → your app → "Submit for Approval".
# Approval typically takes 2–4 weeks. Until approved, only whitelisted devices
# work.
#
# One app ID per environment (leave unset to use the Default Media Receiver
# constant):
# NEXT_PUBLIC_CAST_RECEIVER_APP_ID=ABCD1234   (dev)
# NEXT_PUBLIC_CAST_RECEIVER_APP_ID=EFGH5678   (staging/preview)
# NEXT_PUBLIC_CAST_RECEIVER_APP_ID=IJKL9012   (production)
NEXT_PUBLIC_CAST_RECEIVER_APP_ID=

# -----------------------------------------------------------------------------
# Legacy / future custom receiver (NOT required for v3)
# -----------------------------------------------------------------------------
# A Custom Receiver (separately-registered receiver app ID pointing at
# /songsets/[id]/play/projection or /share/[token]/play/projection) is only
# relevant if lyrics stop being baked into the MP4 and a custom on-receiver UI
# is reintroduced. The Default Media Receiver above is sufficient for v3.
#
# To register a Custom Receiver (only if needed in the future):
#   1. Go to https://cast.google.com/publish and sign in with a Google account.
#   2. Click "Add New Application" → "Custom Receiver".
#   3. Enter the receiver URL:
#      - Dev:     http://localhost:8080/songsets/<songset-id>/play/projection
#      - Staging: https://staging.your-app.vercel.app/songsets/<songset-id>/play/projection
#      - Prod:    https://your-app.vercel.app/songsets/<songset-id>/play/projection
#   4. Save the generated 8-character App ID and set it as
#      NEXT_PUBLIC_CAST_RECEIVER_APP_ID above for the matching environment.
#
# When NEXT_PUBLIC_CAST_RECEIVER_APP_ID is unset, Cast integration uses the
# Default Media Receiver constant (production guidance for v3); the W3C
# Presentation API browser-projection fallback (src/hooks/usePresentation.ts)
# is retained only for developer/browser-projection debugging, not live use.

# -----------------------------------------------------------------------------
# AWS SQS (Render Job Queue)
# -----------------------------------------------------------------------------
# The Next.js app enqueues render jobs to SQS instead of running the pipeline
# inline. An AWS Lambda container worker picks up jobs from the queue.
#
# AWS region where the SQS queue and Lambda function are deployed.
SOW_AWS_REGION=us-east-1

# URL of the SQS queue that receives render job messages.
# Format: https://sqs.<region>.amazonaws.com/<account-id>/<queue-name>
# Example: https://sqs.us-east-1.amazonaws.com/123456789012/sow-render-jobs
SOW_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/sow-render-jobs

# AWS credentials for sending messages to SQS from the Next.js app.
# Create an IAM user with the following minimum permissions:
#   - sqs:SendMessage on the render jobs queue ARN
#   - sqs:GetQueueUrl (optional, if constructing queue URL dynamically)
#
# Alternatively, if deploying on Vercel with AWS IAM role integration,
# you may omit these and rely on the default credential provider chain.
SOW_AWS_ACCESS_KEY_ID=your-aws-access-key-id
SOW_AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# Custom SQS endpoint URL (optional).
# Only needed for non-AWS SQS-compatible services (e.g., LocalStack for local dev).
# Leave unset for production AWS deployments.
SOW_SQS_ENDPOINT_URL=

# Render worker dispatch mode: "sqs" (default, production) or "rest" (local dev with Docker).
# In production, always use "sqs" to enqueue jobs to AWS SQS.
# In local dev, use "rest" to invoke the render worker Docker container directly via its RIE endpoint.
# NOTE: In "rest" mode, the API route blocks until the render completes (4+ min for video).
SOW_RENDER_WORKER_MODE=sqs

# Render worker REST URL (only used when SOW_RENDER_WORKER_MODE=rest).
# Default: http://localhost:9000/2015-03-31/functions/function/invocations
# Leave unset in production (not used when mode is "sqs").
SOW_RENDER_WORKER_REST_URL=

# -----------------------------------------------------------------------------
# App URL (public, embedded in client bundle)
# -----------------------------------------------------------------------------
# Full base URL of the deployed app — used for share links, OG tags, etc.
NEXT_PUBLIC_BASE_URL=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# LLM API (Semantic Search)
# -----------------------------------------------------------------------------
# OpenAI-compatible API key for text-embedding-3-small, used by the "Describe"
# tab in Browse Sheet to embed user queries for semantic song search.
# Supports: OpenRouter, OpenAI, NeuralWatt, etc.
# Cost: ~$0.02/1M tokens; typical query is ~10 tokens.
SOW_LLM_API_KEY=

# OpenAI-compatible API base URL for embedding generation.
# Required — must be set even when using OpenAI directly.
# Examples:
#   - OpenAI: https://api.openai.com/v1
#   - OpenRouter: https://openrouter.ai/api/v1
SOW_LLM_BASE_URL=

# Provider-specific embedding model name for API calls.
# Defaults to "text-embedding-3-small" if not set.
# Examples:
#   - OpenAI direct: text-embedding-3-small
#   - OpenRouter: openai/text-embedding-3-small
SOW_LLM_EMBEDDING_MODEL=

# -----------------------------------------------------------------------------
# Upstash Redis (client-error telemetry rate limiting)
# -----------------------------------------------------------------------------
# The POST /api/log-client-error endpoint (best-effort, anonymized, unauthenticated
# sink for Cast/Presentation transport errors) is rate-limited via an Upstash
# Redis token bucket (20 req/min per hashed client IP).
#
# RECOMMENDED for production. When BOTH vars below are unset, the rate limiter
# is null and the endpoint degrades to an allow-all fallback (no throttling) —
# fine for dev/test, but an unbounded telemetry sink in production.
#
# Provision an Upstash Redis instance at https://console.upstash.com (free tier
# suffices; the endpoint is best-effort, ~20 req/min). Rotation of these
# credentials requires a Vercel redeploy (the limiter is cached per warm
# instance).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
